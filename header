<script>
/* ─── Header Scroll Effect ──────────────────────────────── */
(function() {
  var header = document.querySelector('.indexia-header');
  var heroSection = document.querySelector('.hero'); // Ajuste le sélecteur si nécessaire
  
  function updateHeaderBackground() {
    if (!heroSection) return;
    
    var heroBottom = heroSection.offsetTop + heroSection.offsetHeight;
    var scrollPos = window.scrollY;
    
    if (scrollPos > heroBottom - 100) {
      header.classList.remove('is-transparent');
      header.classList.add('is-solid');
    } else {
      header.classList.remove('is-solid');
      header.classList.add('is-transparent');
    }
  }
  
  window.addEventListener('scroll', updateHeaderBackground, { passive: true });
  updateHeaderBackground(); // Check initial state
})();

/* ─── Burger Menu Toggle ────────────────────────────────── */
(function() {
  var burger = document.getElementById('headerBurger');
  var dropdown = document.getElementById('headerDropdown');
  var mobileMenu = document.getElementById('headerMobileMenu');
  
  if (!burger) return;
  
  burger.addEventListener('click', function() {
    var isMobile = window.innerWidth <= 768;
    
    burger.classList.toggle('is-active');
    
    if (isMobile) {
      // Mobile: fullscreen menu
      mobileMenu.classList.toggle('is-open');
      document.body.style.overflow = mobileMenu.classList.contains('is-open') ? 'hidden' : '';
    } else {
      // Tablet/Laptop: dropdown
      dropdown.classList.toggle('is-open');
    }
  });
  
  // Fermer le menu si on clique sur un lien
  var menuLinks = document.querySelectorAll('.header-mobile-menu a, .header-dropdown-menu a');
  menuLinks.forEach(function(link) {
    link.addEventListener('click', function() {
      burger.classList.remove('is-active');
      mobileMenu.classList.remove('is-open');
      dropdown.classList.remove('is-open');
      document.body.style.overflow = '';
    });
  });
  
  // Fermer dropdown si on clique ailleurs
  document.addEventListener('click', function(e) {
    if (!burger.contains(e.target) && !dropdown.contains(e.target)) {
      dropdown.classList.remove('is-open');
      burger.classList.remove('is-active');
    }
  });
})();
</script>
